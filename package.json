{
  "name": "coachinclaw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev --workspace @coachinclaw/web",
    "dev:worker": "npm run dev --workspace @coachinclaw/worker",
    "db:generate": "npm run db:generate --workspace @coachinclaw/db",
    "db:migrate": "npm run db:migrate --workspace @coachinclaw/db",
    "db:studio": "npm run db:studio --workspace @coachinclaw/db",
    "selfhost:up": "bash ./scripts/run-compose.sh up --build",
    "selfhost:down": "bash ./scripts/run-compose.sh down",
    "selfhost:logs": "bash ./scripts/run-compose.sh logs -f web worker db",
    "selfhost:migrate": "bash ./scripts/run-compose.sh run --rm migrate",
    "build": "npm run build --workspaces --if-present --include-workspace-root=false",
    "lint": "npm run lint --workspaces --if-present --include-workspace-root=false",
    "typecheck": "npm run typecheck --workspaces --if-present --include-workspace-root=false",
    "check": "npm run lint && npm run typecheck",
    "issues:deferred": "tsx scripts/create-deferred-issues.ts"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.5",
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
